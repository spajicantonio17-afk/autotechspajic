# --- Javna adresa stranice (za sitemap, canonical, OG, JSON-LD) ---
# Lokalno nije potrebno. Na Vercelu postaviti čim postoji vlastita domena,
# npr. https://autotechspajic.com — bez ove varijable koristi se VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# --- Interni pristup (timska lozinka za /termin) ---
INTERNAL_PASSWORD=odaberite-lozinku

# --- Supabase (tablica prodaje za /termin/pregled) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxx

# --- Google Calendar (Service Account) ---
# 1. Google Cloud Console -> aktiviraj "Google Calendar API"
# 2. Kreiraj Service Account -> dodaj ključ (JSON) -> preuzmi
# 3. U Google Calendar podijeli ciljani kalendar s e-mailom servisnog računa
#    (dozvola: "Izmjene događaja / Make changes to events")
# 4. Popuni vrijednosti ispod iz JSON-a:

GOOGLE_SERVICE_ACCOUNT_EMAIL=ime@projekt.iam.gserviceaccount.com

# Cijeli private_key iz JSON-a, u jednom redu, s \n umjesto prijeloma:
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ID kalendara (Calendar settings -> "Integrate calendar" -> Calendar ID):
GOOGLE_CALENDAR_ID=xxxxx@group.calendar.google.com
